# MyQuiz.ai-backend — 複製此檔為 .env 並填入實際值（.env 不會被 git 追蹤）
# 以下為後端會讀取的主要環境變數。main.py 啟動時會 load_dotenv() 載入本檔。

# --- CORS（前端改網域／本機換埠／Vercel 改專案名後網址變了時）---
# main.py 內建已含 localhost／127.0.0.1 的 8080–8086、5173（Vite）、4173、3000 等。
# 若用區網 IP 開前端（例 http://192.168.0.10:8081），瀏覽器 origin 不同，必須追加：
# CORS_EXTRA_ORIGINS=http://192.168.0.10:8081
# 其它埠同樣以逗號分隔追加。
# CORS_EXTRA_ORIGINS=

# --- Supabase（課程系統／使用者）---
# 到 Supabase Dashboard → Project Settings → API 取得
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...或 sb_publishable_...

# 後端用（可略過 RLS）— Legacy API Keys → service_role，或 API Keys → Secret key (sb_secret_...)
SUPABASE_SERVICE_ROLE_KEY=

# 若用新版 Secret key 可選填（有 service_role 則不必）
# SUPABASE_SECRET_KEY=sb_secret_...

# --- Supabase Storage（上傳 ZIP / RAG ZIP）---
# 存放上傳 ZIP 與 RAG FAISS ZIP 的 Supabase Storage bucket 名稱（預設 "MyQuiz-ai"）
# 到 Supabase Dashboard → Storage → Buckets 建立同名 bucket 後填入
SUPABASE_RAG_BUCKET=MyQuiz-ai

# --- Course_Setting（LLM API Key、分析 prompt 等）---
# 依 course_id 存於 Course_Setting；rag-api-key、exam-api-key 以 GET/PUT /rag/llm_api_key、/exam/llm_api_key 管理
# 個人分析：Person_Analysis_Setting（指令／報告）；課程分析：Course_Setting（course_analysis_user_prompt_text、course_analysis_text）

# --- Deepgram（音檔轉文字等）---
# 必填（若會用到 Deepgram）；僅讀環境變數
# 到 https://console.deepgram.com/ 建立 API Key；勿將金鑰提交到 git
# DEEPGRAM_API_KEY=
# 可選，預設 nova-2；見 Deepgram 文件之 model 名稱
# DEEPGRAM_MODEL=nova-2
# 呼叫 Deepgram 逾時（秒），預設 900
# DEEPGRAM_REQUEST_TIMEOUT_SECONDS=900
