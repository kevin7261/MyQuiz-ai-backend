# myQUIZ.ai 後端 — 複製此檔為 .env 並填入實際值（.env 不會被 git 追蹤）
# 以下為後端會讀取的主要環境變數。main.py 啟動時會 load_dotenv() 載入本檔。

# --- 認證（Bearer token，POST /v1/auth/login 簽發）---
# token HMAC-SHA256 簽章密鑰；未設定時退回 SUPABASE_SERVICE_ROLE_KEY 衍生值（開發方便用）。
# 正式環境建議獨立設定；變更後所有已簽發 token 失效（使用者需重新登入）。
# AUTH_TOKEN_SECRET=
# token 效期秒數，預設 2592000（30 天）
# AUTH_TOKEN_TTL_SECONDS=2592000

# --- CORS（前端改網域／本機換埠／Vercel 改專案名後網址變了時）---
# main.py 內建已含 localhost／127.0.0.1 的 8080–8086、5173（Vite）、4173、3000 等。
# 若用區網 IP 開前端（例 http://192.168.0.10:8081），瀏覽器 origin 不同，必須追加：
# CORS_EXTRA_ORIGINS=http://192.168.0.10:8081
# 其它埠同樣以逗號分隔追加。
# CORS_EXTRA_ORIGINS=

# --- Supabase（課程系統／使用者）---
# 到 Supabase Dashboard → Project Settings → API 取得
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...或 sb_publishable_...

# 後端用（可略過 RLS）— Legacy API Keys → service_role，或 API Keys → Secret key (sb_secret_...)
SUPABASE_SERVICE_ROLE_KEY=

# 若用新版 Secret key 可選填（有 service_role 則不必）
# SUPABASE_SECRET_KEY=sb_secret_...

# --- Supabase Storage（上傳 ZIP / RAG ZIP）---
# 存放上傳 ZIP 與 RAG FAISS ZIP 的 Supabase Storage bucket 名稱（預設 "myQUIZ.ai"）
# 到 Supabase Dashboard → Storage → Buckets 建立同名 bucket 後填入
SUPABASE_RAG_BUCKET=myQUIZ.ai

# --- Course_Setting（LLM API Key、分析 prompt 等，不放 .env）---
# 依 course_id 存於 Course_Setting；rag-api-key、exam-api-key 以
# GET/PUT /v1/rag/llm-api-key、/v1/exam/llm-api-key 管理；LLM 模型為 key=llm-model（GET/PUT /v1/rag/llm-model）。
# 個人分析：Person_Analysis（指令／報告）；課程分析：Course_Analysis（指令／報告）
