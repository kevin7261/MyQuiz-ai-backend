# Supabase（課程系統／使用者）
# 複製此檔為 .env 並填入實際值（.env 不會被 git 追蹤）
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...或 sb_publishable_...

# 後端用（可略過 RLS）— 到 Supabase → Project Settings → API 取得：
# Legacy API Keys → service_role，或 API Keys → Secret key (sb_secret_...)
SUPABASE_SERVICE_ROLE_KEY=
