# MyQuiz.ai-backend — 複製此檔為 .env 並填入實際值（.env 不會被 git 追蹤）
# 以下為後端會讀取的主要環境變數。main.py 啟動時會 load_dotenv() 載入本檔。

# --- CORS（前端改網域／本機換埠／Vercel 改專案名後網址變了時）---
# main.py 內建已含 localhost／127.0.0.1 的 8080、8081、5173（Vite）、4173、3000 等。
# 若用區網 IP 開前端（例 http://192.168.0.10:8081），瀏覽器 origin 不同，必須追加：
# CORS_EXTRA_ORIGINS=http://192.168.0.10:8081
# 其它埠同樣以逗號分隔追加。
# CORS_EXTRA_ORIGINS=

# --- Supabase（課程系統／使用者）---
# 到 Supabase Dashboard → Project Settings → API 取得
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...或 sb_publishable_...

# 後端用（可略過 RLS）— Legacy API Keys → service_role，或 API Keys → Secret key (sb_secret_...)
SUPABASE_SERVICE_ROLE_KEY=

# 若用新版 Secret key 可選填（有 service_role 則不必）
# SUPABASE_SECRET_KEY=sb_secret_...

# --- Supabase Storage（上傳 ZIP / RAG ZIP）---
# 存放上傳 ZIP 與 RAG FAISS ZIP 的 Supabase Storage bucket 名稱（預設 "rag"）
# 到 Supabase Dashboard → Storage → Buckets 建立同名 bucket 後填入
SUPABASE_RAG_BUCKET=rag

# --- LLM（OpenAI 相容 API Key；exam／person_analysis 等用環境變數）---
# 填其一即可；Rag 出題等路徑另可從 User.llm_api_key 讀取，無則 fallback 至此
# LLM_API_KEY=sk-...
# OPENAI_API_KEY=sk-...

# --- Deepgram（音檔轉文字等）---
# 必填（若會用到 Deepgram）；僅讀環境變數，不再經 System_Setting
# 到 https://console.deepgram.com/ 建立 API Key；勿將金鑰提交到 git
# DEEPGRAM_API_KEY=
# 可選，預設 nova-2；見 Deepgram 文件之 model 名稱
# DEEPGRAM_MODEL=nova-2
# 呼叫 Deepgram 逾時（秒），預設 900
# DEEPGRAM_REQUEST_TIMEOUT_SECONDS=900

# --- YouTube 字幕（youtube-transcript-api；GET /rag/transcript/youtube、unit_type=4 建逐字稿）---
# 未指定 API 的 languages 參數時，依此逗號順序嘗試字幕（前者優先）；可省略則用內建 en→中文→日韓
# YOUTUBE_TRANSCRIPT_LANGUAGES=en,zh-Hant,zh-TW
# 雲端 IP 常被 YouTube 擋：設代理可避免。結尾 / 可有可無；HTTPS 未設時會自動沿用 HTTP 代理。
# 若未設下列兩項，後端會再讀取標準 HTTP_PROXY／HTTPS_PROXY（部署平台常用）。
# YOUTUBE_TRANSCRIPT_HTTP_PROXY=http://user:pass@proxy.example.com:5659/
# YOUTUBE_TRANSCRIPT_HTTPS_PROXY=
# Webshare 住宅代理（與套件 README）：YOUTUBE_TRANSCRIPT_WEBSHARE_USERNAME／PASSWORD 等
# 自訂 HTTP 代理時：遇阻擋重試次數（預設 8）；輪換 IP 可加大；靜態單一 IP 可設 0
# YOUTUBE_TRANSCRIPT_PROXY_RETRIES_WHEN_BLOCKED=8
# 預設每次請求關 TCP（利於輪換）；靜態代理若異常可試 YOUTUBE_TRANSCRIPT_PROXY_CLOSE_CONNECTION=0
# YOUTUBE_TRANSCRIPT_PROXY_CLOSE_CONNECTION=1
